generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model BillingLedger {
  id                String   @id @default("singleton")
  cycleStart        DateTime
  cycleDayOfMonth   Int      @default(1)
  totalCostUsd      Float    @default(0)
  totalInputTokens  Int      @default(0)
  totalOutputTokens Int      @default(0)
  sessionCount      Int      @default(0)
  lastUpdated       DateTime
}

model Conversation {
  id        String   @id
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime
  status    String   @default("active")
  domain    String?
}

model ConversationMessage {
  id             String   @id
  conversationId String
  timestamp      DateTime @default(now())
  role           String
  type           String
  content        String
  mode           String?
  costUsd        Float?
  commandId      String?

  @@index([conversationId, timestamp])
}

model E2ELearning {
  id         String   @id
  learningId String
  testRunId  String
  testId     String
  createdAt  DateTime @default(now())

  @@unique([learningId, testRunId])
  @@index([testId, createdAt])
}

model E2EScheduledJob {
  id                 String       @id @default(cuid())
  testId             String       @unique
  cronSchedule       String
  notificationConfig Json?
  enabled            Boolean      @default(true)
  lastRunAt          DateTime?
  nextRunAt          DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime
  E2ETest            E2ETest      @relation(fields: [testId], references: [id], onDelete: Cascade)
  E2ETestRun         E2ETestRun[]
}

model E2ETest {
  id                      String              @id
  name                    String
  description             String?
  domain                  String
  definition              Json
  scope                   String              @default("global")
  createdAt               DateTime            @default(now())
  updatedAt               DateTime
  versionNumber           Int                 @default(1)
  isActive                Boolean             @default(true)
  retryCount              Int                 @default(2)
  strictnessLevel         String              @default("medium")
  setupSteps              Json?
  teardownSteps           Json?
  timeout                 Int                 @default(300000)
  visualRegressionEnabled Boolean             @default(true)
  autoApproveBaseline     Boolean             @default(false)
  visualFuzzyThreshold    Float               @default(0.98)
  notifyOnFailure         String[]            @default([])
  notifyOnSuccess         Boolean             @default(false)
  cronSchedule            String?
  nextScheduledRun        DateTime?
  lastScheduledRun        DateTime?
  useStoredProfile        Boolean             @default(false)
  E2EScheduledJob         E2EScheduledJob?
  E2ETestRun              E2ETestRun[]
  E2ETestVersion          E2ETestVersion[]
  E2EVisualBaseline       E2EVisualBaseline[]

  @@index([cronSchedule])
  @@index([domain])
  @@index([scope, isActive])
}

model E2ETestRun {
  id              String           @id @default(cuid())
  testId          String
  isScheduled     Boolean          @default(false)
  scheduledJobId  String?
  status          String           @default("running")
  verdict         String?
  passedRetry     Int?
  startedAt       DateTime         @default(now())
  completedAt     DateTime?
  durationMs      Int?
  errorMessage    String?
  costUsd         Float            @default(0)
  E2EScheduledJob E2EScheduledJob? @relation(fields: [scheduledJobId], references: [id])
  E2ETest         E2ETest          @relation(fields: [testId], references: [id], onDelete: Cascade)
  E2ETestStep     E2ETestStep[]
  E2EVisualDiff   E2EVisualDiff[]

  @@index([status])
  @@index([testId, startedAt])
}

model E2ETestStep {
  id           String     @id @default(cuid())
  runId        String
  stepNumber   Int
  instruction  String
  status       String
  result       String?
  screenshot   String?
  durationMs   Int?
  errorMessage String?
  retryCount   Int        @default(0)
  E2ETestRun   E2ETestRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, stepNumber])
}

model E2ETestVersion {
  id           String   @id
  testId       String
  version      Int
  definition   Json
  createdAt    DateTime @default(now())
  changedBy    String?
  changeReason String?
  E2ETest      E2ETest  @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([testId, version])
  @@index([testId])
}

model E2EVisualBaseline {
  id             String    @id @default(cuid())
  testId         String
  stepNumber     Int
  screenshotPath String
  createdAt      DateTime  @default(now())
  approvedAt     DateTime?
  approvedBy     String?
  E2ETest        E2ETest   @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([testId, stepNumber])
  @@index([testId])
}

model E2EVisualDiff {
  id           String     @id @default(cuid())
  runId        String
  stepNumber   Int
  baselinePath String
  currentPath  String
  diffPath     String
  similarity   Float
  approved     Boolean    @default(false)
  E2ETestRun   E2ETestRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
}

model Learning {
  id           String   @id
  domain       String
  category     String
  pattern      String
  confidence   Float
  sourceTaskId String
  created      DateTime

  @@unique([domain, pattern])
}

model SessionEntry {
  id        Int      @id @default(autoincrement())
  sessionId String
  timestamp DateTime
  role      String
  content   String
  mode      String?
  costUsd   Float?

  @@index([sessionId])
}

model SiteKnowledge {
  id              String   @id
  domain          String   @unique
  lastUpdated     DateTime
  siteDescription String?
  techStack       String[]
  authMethod      String?
  pages           Json     @default("{}")
  siteMap         String[]
  commonFlows     String[]
  knownIssues     String[]
  tips            String[]
}

model TaskRecord {
  id          String   @id
  timestamp   DateTime
  command     String
  instruction String
  mode        String
  domain      String?
  steps       String[]
  outcome     String
  result      String?
  durationMs  Int
  costUsd     Float
  tokensIn    Int
  tokensOut   Int
}

model TestReport {
  id         String   @id
  title      String
  timestamp  DateTime
  domain     String
  steps      Json
  verdict    String
  summary    String
  durationMs Int
  costUsd    Float
}
